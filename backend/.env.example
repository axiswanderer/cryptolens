# Database — for Neon use the connection string from your project dashboard
# Local:  postgresql://postgres:password@localhost:5432/cryptolens
# Neon:   postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:db_password@localhost:5432/cryptolens

# Binance API (get from https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# App
ENV=development
MODEL_PATH=./models/xgboost_model.joblib
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
# Production example: https://cryptolens.vercel.app,https://yourcustomdomain.com
ALLOWED_ORIGINS=http://localhost:3000
